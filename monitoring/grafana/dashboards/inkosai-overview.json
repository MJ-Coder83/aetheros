{
  "dashboard": {
    "id": null,
    "title": "InkosAI Overview",
    "tags": ["inkosai", "overview"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Service Health",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"inkosai-api\"}",
            "legendFormat": "API Status"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "HTTP Requests / Second",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(inkosai_http_requests_total[5m])",
            "legendFormat": "{{method}} {{endpoint}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Average Response Time",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(inkosai_http_request_duration_seconds_sum[5m]) / rate(inkosai_http_request_duration_seconds_count[5m])",
            "legendFormat": "{{method}} {{endpoint}}"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 4,
        "title": "Domain Operations",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(inkosai_domains_created_total[5m])",
            "legendFormat": "Domains Created"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 4}
      },
      {
        "id": 5,
        "title": "Swarm Invocations",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(inkosai_swarm_invocations_total[5m])",
            "legendFormat": "{{domain}}"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 4}
      },
      {
        "id": 6,
        "title": "Plugin Executions",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(inkosai_plugins_executed_total[5m])",
            "legendFormat": "{{plugin_id}}"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 4}
      },
      {
        "id": 7,
        "title": "Authentication Events",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(inkosai_auth_events_total[5m])",
            "legendFormat": "{{event_type}} - {{result}}"
          }
        ],
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 10}
      },
      {
        "id": 8,
        "title": "Canvas Operations",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(inkosai_canvas_operations_total[5m])",
            "legendFormat": "{{operation}}"
          }
        ],
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 10}
      }
    ]
  }
}
